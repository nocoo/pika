#!/usr/bin/env sh

bun run test:coverage 2>&1
TEST_EXIT=$?
if [ $TEST_EXIT -ne 0 ]; then
  echo "❌ pre-push FAILED: Unit tests or coverage threshold (90%) not met."
  exit 1
fi

bun run lint 2>&1
LINT_EXIT=$?
if [ $LINT_EXIT -ne 0 ]; then
  echo "❌ pre-push FAILED: TypeScript type check errors."
  exit 1
fi

echo "✅ pre-push passed: UT + Coverage ≥90% + Lint"
